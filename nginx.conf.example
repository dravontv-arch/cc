# Nginx конфигурация для URL Shortener
# Добавьте этот блок в ваш nginx.conf или в файл сайта в /etc/nginx/conf.d/

server {
    listen 80;
    server_name your-domain.com;  # Замените на ваш домен
    
    root /var/www/url-shortener;  # Путь к файлам сайта
    index index.php;
    
    # Защита служебных файлов
    location ~ ^/(config\.php|install\.php)$ {
        deny all;
        return 404;
    }
    
    # Админ-панель
    location /admin/ {
        try_files $uri $uri/ /admin/index.php?$query_string;
        
        location ~ \.php$ {
            include fastcgi_params;
            fastcgi_pass unix:/run/php/php8.0-fpm.sock;  # Или 127.0.0.1:9000
            fastcgi_param SCRIPT_FILENAME $document_root$fastcgi_script_name;
            fastcgi_index index.php;
        }
    }
    
    # API
    location /api/ {
        try_files $uri $uri/ /api/shorten.php?$query_string;
        
        location ~ \.php$ {
            include fastcgi_params;
            fastcgi_pass unix:/run/php/php8.0-fpm.sock;
            fastcgi_param SCRIPT_FILENAME $document_root$fastcgi_script_name;
            fastcgi_index index.php;
        }
    }
    
    # Статические файлы (CSS, JS, изображения)
    location /assets/ {
        expires 30d;
        add_header Cache-Control "public, immutable";
    }
    
    # Обработка коротких ссылок
    location ~ ^/([a-zA-Z0-9_-]+)$ {
        try_files $uri $uri/ /redirect.php?code=$1;
        
        location ~ \.php$ {
            include fastcgi_params;
            fastcgi_pass unix:/run/php/php8.0-fpm.sock;
            fastcgi_param SCRIPT_FILENAME $document_root$fastcgi_script_name;
            fastcgi_index index.php;
        }
    }
    
    # Главный redirect.php
    location = /redirect.php {
        include fastcgi_params;
        fastcgi_pass unix:/run/php/php8.0-fpm.sock;
        fastcgi_param SCRIPT_FILENAME $document_root$fastcgi_script_name;
        fastcgi_index index.php;
    }
    
    # Основной PHP обработчик
    location ~ \.php$ {
        try_files $uri =404;
        include fastcgi_params;
        fastcgi_pass unix:/run/php/php8.0-fpm.sock;  # Или 127.0.0.1:9000
        fastcgi_param SCRIPT_FILENAME $document_root$fastcgi_script_name;
        fastcgi_index index.php;
        fastcgi_buffer_size 128k;
        fastcgi_buffers 4 256k;
        fastcgi_busy_buffers_size 256k;
    }
    
    # Запрет доступа к скрытым файлам
    location ~ /\. {
        deny all;
    }
    
    # Логи
    access_log /var/log/nginx/url-shortener-access.log;
    error_log /var/log/nginx/url-shortener-error.log;
}

# Для HTTPS раскомментируйте и настройте SSL
